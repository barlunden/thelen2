---
// src/layouts/Layout.astro
interface Props {
	title?: string;
	description?: string;
}

const { 
  title = "Steinar Thelen | Magisk Underholdning", 
  description = "Opplev førsteklasses magi med tryllekunstner Steinar Thelen." 
} = Astro.props;

import NavBar from '../components/NavBar.astro';
import ContactDrawer from '../components/ContactDrawer.astro'
import '../styles/global.css';
---

<!doctype html>
<html lang="no" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,600;1,300&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
	</head>
	<body class="bg-warm-gray text-deep-gray antialiased selection:bg-sparkle/30">
		
		<div class="fixed inset-0 pointer-events-none z-50 opacity-[0.03] bg-[url('/noise.png')]"></div>

		<NavBar />
    
		<main>
			<slot />
		</main>

		<footer class="bg-deep-gray text-white/60 py-20 px-8 text-center border-t border-white/5">
			<p class="text-xs uppercase tracking-[0.5em] mb-4 text-sparkle">Steinar Thelen</p>
			<p class="font-light italic">&copy; {new Date().getFullYear()} — Comino Web Standard</p>
		</footer>
		<ContactDrawer />
	</body>
</html>