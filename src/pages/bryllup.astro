---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Quote from "../components/Quote.astro";
import CTA from "../components/CTA.astro";

// Importer spesifikke bilete for bryllup
import weddingHero from "../assets/images/DMCfest261023-100.jpg";
import weddingAction from "../assets/images/bryllup.png";
---

<Layout 
  title="Magisk Underholdning til Bryllup | Steinar Thelen"
  description="Gjer bryllupsdagen unik med stilfull og engasjerande magi som samlar gjestene."
>
  
  <Hero 
    title="En uforglemmelig dag" 
    subtitle="Magisk underholdning for bryllup"
    imagePath={weddingHero}
    height="h-[80vh]"
  />

  <Quote 
    text="Magi er den perfekte isbryteren mellom to familier som møtes for første gang."
  />

  <CTA 
    title="Eksklusiv Trylling"
    description="For de helt spesielle anledningene der bare det ypperste er godt nok."
    kind="gold"
  />
  <section class="max-w-6xl mx-auto py-24 px-8">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      
      <div class="relative order-2 md:order-1">
        <Image 
          src={weddingAction} 
          alt="Gjester som ler og blir imponert i et bryllup" 
          class="rounded-2xl shadow-xl"
        />
        <div class="absolute -top-4 -right-4 w-24 h-24 border-t-2 border-r-2 border-sparkle/40 rounded-tr-2xl -z-10"></div>
      </div>
      <div class="space-y-8 order-1 md:order-2">
        <h2 class="text-4xl md:text-5xl font-serif italic text-deep-gray">
          Skap minner gjestene aldri glemmer
        </h2>
        
        <div class="space-y-4 text-lg text-deep-gray/80 leading-relaxed font-light">
          <p>
            I et bryllup er det ofte naturlige pauser – under fotografering eller før middagen. 
            Steinar beveger seg diskret blant gjestene og leverer "close-up" magi som skaper 
            latter, undring og samtaleemner på tvers av bordene.
          </p>
          <p>
            Dette er ikke bare triks; det er en elegant måte å binde sammen selskapet på, 
            levert med varme og profesjonalitet som passer en stor dag.
          </p>
        </div>

        <div class="pt-4">
          <a href="#kontakt" class="text-sparkle-shadow font-semibold uppercase tracking-widest text-sm border-b-2 border-sparkle pb-1 hover:text-deep-gray transition-colors">
            Sjekk tilgjengelighet for deres dato
          </a>
        </div>
      </div>

    </div>
  </section>

  <Quote 
    text="Steinar var prikken over i-en i vårt bryllup. Gjestene snakker om det enda!" 
    author="Lise & Markus, Brudepar"
  />

  <section class="bg-deep-gray py-20 text-center text-white px-8">
    <h3 class="text-3xl md:text-5xl font-serif mb-8 italic">Vil dere ha magi i deres bryllup?</h3>
    <p class="max-w-xl mx-auto text-white/60 mb-10 font-light">
      Ta kontakt for en uforpliktende samtale om hvordan vi kan tilpasse underholdningen til deres tidsplan og ønsker.
    </p>
    <a href="#kontakt" class="bg-white text-deep-gray px-10 py-4 rounded-full font-bold hover:bg-sparkle hover:text-white transition-all">
      Send forespørsel
    </a>
  </section>

</Layout>